# ================================
# Database Configuration
# ================================
DATABASE_URL=postgresql://user:password@host:port/database

# ================================
# Redis Configuration (REQUIRED in Production)
# ================================
# Redis is REQUIRED in production for distributed rate limiting across API instances
# Development can work without Redis (uses in-memory fallback)
# Format: redis://[user:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ================================
# API Server Configuration
# ================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ================================
# Frontend Configuration
# ================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Site URL for metadata and OG images (production)
NEXT_PUBLIC_SITE_URL=https://blink402.dev

# Solana Configuration
# Network: 'devnet' or 'mainnet-beta'
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoints (client and server)
# For production, use a dedicated RPC provider like Helius, QuickNode, or Triton
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# USDC Token Mint (devnet)
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ================================
# Testing Configuration
# ================================
# Enable mock payment verification (bypasses real Solana RPC calls)
# ONLY for development/testing - automatically disabled in production
# MOCK_PAYMENTS=true

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
